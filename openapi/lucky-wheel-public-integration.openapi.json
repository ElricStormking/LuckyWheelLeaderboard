{
  "openapi": "3.0.3",
  "info": {
    "title": "Lucky Wheel Public Integration API",
    "version": "1.3.0",
    "description": "Customer-platform-facing Lucky Wheel launch API."
  },
  "servers": [
    {
      "url": "https://merchant-api.luckywheel.example.com/merchant-api",
      "description": "Production"
    },
    {
      "url": "https://sandbox-merchant-api.luckywheel.example.com/merchant-api",
      "description": "Sandbox"
    }
  ],
  "tags": [
    {
      "name": "Public Integration"
    }
  ],
  "paths": {
    "/integration/launch": {
      "post": {
        "tags": [
          "Public Integration"
        ],
        "summary": "Launch Lucky Wheel",
        "description": "Creates a Lucky Wheel launch session for a customer-platform player and returns a game URL. The request uses a shared X-Integration-Guid header plus timestamp freshness validation. Merchant API resolves the single configured merchant from server config. Customer Platform also sends initialEligibility bootstrap data on launch, and Lucky Wheel reloads authoritative eligibility after launch.",
        "parameters": [
          {
            "$ref": "#/components/parameters/XIntegrationGuid"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LaunchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Launch response envelope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LaunchEnvelope"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "XIntegrationGuid": {
        "name": "X-Integration-Guid",
        "in": "header",
        "required": true,
        "description": "Shared integration GUID assigned during onboarding for launch authentication.",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "schemas": {
      "LaunchRequest": {
        "type": "object",
        "required": [
          "playerId",
          "initialEligibility",
          "timestamp"
        ],
        "properties": {
          "playerId": {
            "type": "string"
          },
          "initialEligibility": {
            "$ref": "#/components/schemas/InitialEligibilityBootstrap"
          },
          "timestamp": {
            "type": "integer",
            "description": "Unix timestamp in seconds used for freshness validation."
          }
        }
      },
      "InitialEligibilityBootstrap": {
        "type": "object",
        "required": [
          "depositQualified"
        ],
        "properties": {
          "depositQualified": {
            "type": "boolean"
          }
        },
        "additionalProperties": false,
        "description": "Customer-platform bootstrap eligibility data sent on launch. This object is not authoritative for Lucky Wheel gameplay."
      },
      "LaunchData": {
        "type": "object",
        "required": [
          "url",
          "sessionId",
          "expiresAt"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "sessionId": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LaunchEnvelope": {
        "type": "object",
        "required": [
          "success",
          "errorCode",
          "errorMessage",
          "data"
        ],
        "properties": {
          "success": {
            "type": "boolean"
          },
          "errorCode": {
            "type": "integer"
          },
          "errorMessage": {
            "type": "string"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/LaunchData"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    }
  }
}

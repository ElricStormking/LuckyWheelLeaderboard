# Copy this file to .env.production on the server and replace placeholders.

# Public URLs
LUCKY_WHEEL_CLIENT_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN:3000

# Internal service auth
MERCHANT_API_SERVICE_TOKEN=replace-with-a-long-random-token

# Lucky Wheel platform launch auth
MERCHANT_INTEGRATION_ID=MERCHANT001
MERCHANT_INTEGRATION_GUID=replace-with-customer-platform-guid
MERCHANT_INTEGRATION_ALLOWED_IPS=*
MERCHANT_INTEGRATION_ACTIVE=true
LUCKY_WHEEL_PLATFORM_MERCHANT_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=file:/data/dev.db
API_AUTO_SEED_DEMO_DATA=false

# App behavior
EVENT_AUTO_FINALIZE_GRACE_MINUTES=30
LUCKY_WHEEL_FILL_TEST_LEADERBOARD=true

# Customer Platform SOAP
CUSTOMER_PLATFORM_SOAP_ENABLED=false
CUSTOMER_PLATFORM_SOAP_URL=https://example.com/iBetService.svc
CUSTOMER_PLATFORM_SOAP_ACTION=http://tempuri.org/IIbetService/LuckyWheel_Deposit_isEligible
CUSTOMER_PLATFORM_COMP_ACCESSKEY=
CUSTOMER_PLATFORM_SITE_ID=A
CUSTOMER_PLATFORM_TIMEOUT_MS=8000
CUSTOMER_PLATFORM_RECORD_DATE_TIMEZONE=Asia/Taipei
CUSTOMER_PLATFORM_DEPOSIT_URL=https://merchant.example.com/deposit
